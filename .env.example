# =============================================================
# Lumi — Root Environment Variables Example
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# =============================================================

# --- Database (shared by backend) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=lumi

DATABASE_URL=postgresql+asyncpg://postgres:your_strong_password_here@localhost:5432/lumi
DATABASE_URL_SYNC=postgresql://postgres:your_strong_password_here@localhost:5432/lumi

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL_HEAVY=gpt-4o
OPENAI_MODEL_LIGHT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o

# --- LangSmith (AI Observability) ---
# Get your free API key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=lumi-financial

# --- Email (for notifications) ---
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=noreply@lumi.app
MAIL_FROM_NAME=Lumi
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# --- App ---
APP_ENV=development
APP_NAME=Lumi
FRONTEND_URL=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
