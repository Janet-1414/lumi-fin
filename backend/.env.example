# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/lumi
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/lumi

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL_HEAVY=gpt-4o
OPENAI_MODEL_LIGHT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o

# LangSmith (Observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=lumi-financial

# Email (FastAPI-Mail)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@lumi.app
MAIL_FROM_NAME=Lumi
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# CORS
CORS_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-Requested-With

# App
APP_ENV=development
APP_NAME=Lumi
FRONTEND_URL=http://localhost:3000
